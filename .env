# ─────────────────────────────────────────────────────────
# Azure Hardened Tag Enforcement — Common Variables
# ─────────────────────────────────────────────────────────

# Management group where policies/initiative are defined and assigned if the MG does not already exist it will be created by the deployment scripts (requires appropriate permissions)
MANAGEMENT_GROUP_ID=hardened-tags-mg

# Initiative and assignment names
INITIATIVE_NAME=tag-enforcement-initiative
ASSIGNMENT_NAME=tag-enforcement-assignment
ASSIGNMENT_DISPLAY_NAME=Tag Enforcement — Owner, CostCode, BusinessUnit

# Path to assignment parameters file (relative to repo root)
ASSIGNMENT_PARAMETERS_FILE=assignment-parameters.json

# Location for the policy assignment (used for managed identity region)
ASSIGNMENT_LOCATION=eastus

# ─────────────────────────────────────────────────────────
# Default tag values (used by Modify_Tags and Validate scripts
# when reading the parameters file is not desired)
# ─────────────────────────────────────────────────────────
DEFAULT_OWNER=TeamAlpha
DEFAULT_COSTCODE=CC-1000
DEFAULT_BUSINESSUNIT=Engineering

# ─────────────────────────────────────────────────────────
# Policy definition names (must match the filenames without .json)
# ─────────────────────────────────────────────────────────
POLICY_DEF_OWNER=enforce-tag-owner
POLICY_DEF_COSTCODE=enforce-tag-costcode
POLICY_DEF_BUSINESSUNIT=enforce-tag-businessunit

# ─────────────────────────────────────────────────────────
# Staging / test infrastructure
# ─────────────────────────────────────────────────────────

# Subscription where test resource groups and resources are created.
# Set to CREATE_NEW to provision a new subscription, or provide an existing subscription ID.
STAGING_SUBSCRIPTION_ID=CREATE_NEW

# Name for the new subscription (only used when STAGING_SUBSCRIPTION_ID=CREATE_NEW)
STAGING_SUBSCRIPTION_NAME=tag-validation-test

# Billing account and profile for new subscription creation.
# Optional — if left blank the script will auto-detect from the current login.
# To override, find values via: az billing account list / az billing profile list
STAGING_BILLING_ACCOUNT_NAME=
STAGING_BILLING_PROFILE_NAME=
STAGING_INVOICE_SECTION_NAME=

# Azure region for staging resources
STAGING_LOCATION=eastus

# Prefix applied to all staging resource groups (for easy identification)
STAGING_RG_PREFIX=hardened-tags

# Resource groups to create (comma-separated, must align with assignment-parameters)
STAGING_RESOURCE_GROUPS=rg-dev,rg-shared,rg-data,rg-prod,rg-staging,rg-finance,rg-marketing,rg-hr
